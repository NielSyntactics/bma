<?php
/** User settings module
  * [Developer]
  * Developer: Mark Reynor D. Magriña
  * Date Created: May. 15, 2018
  * Date Finished: May. 15, 2018
  
  * [Database]
	bgsu, modules, amodules, and class
	
  * [Description]
	This module allows the authorized administrators to set (add, edit or delete) users who will be allowed to access the system. 
	Most of the components created are based on standards file (js/standards/Standards.js, js/standards/Overrides.js, js/standards/Constants.js)
  
 * [Modification]
   
 **/
if ( ! defined('BASEPATH')) exit('No direct script access allowed');
class Usersettings extends CI_Controller {
	
	/* class constructor
	 * initialization of classes to be loaded are all here(libraries not included in the auto load config)
	*/
	public function __construct(){
		parent::__construct();
		setHeader( 'admin/Usersettings_model' );
	}
	
	public function retrieveSearch(){
		$params = getData();
		$view = array();
		if( isset( $params['by'] ) ){			
			if( (int)$params['by'] == 1 ){
				$view = $this->model->getUserDetails( $params );
			}
			elseif( (int)$params['by'] == 2 ){
				$view = array(
					0 => array(
						'id' => 1
						,'name' => 'Administrator'
					)
					,1 => array(
						'id' => 2
						,'name' => 'Secretary'
					)
					,2 => array(
						'id' => 3
						,'name' => 'User'
					)
				);
			}
			elseif( (int)$params['by'] == 3 ){
				$view = $this->model->getUserDetails( $params );
			}
			elseif( (int)$params['by'] == 4 ){
				$view = array(
					0 => array(
						'id' => 0
						,'name' => 'Active'
					)
					,1 => array(
						'id' => 2
						,'name' => 'Inactive'
					)
				);
			}
		}
		array_unshift( $view, array(
			'id' => -1
			,'name' => 'All'
		) );
		die(
			json_encode(
				array(
					'success' => true
					,'view' => $view
					,'total' => count( $view )
				)
			)
		);
	}
	
	public function getUserListing(){
		$params = getData();
		$params['pdf'] = false; $params['cnt'] = false;
		$view = $this->model->viewAll( $params );
		$params['pdf'] = true; $params['cnt'] = true;
		$countAll = $this->model->viewAll( $params );
		die(
			json_encode(
				array(
					'success' => true
					,'view' => $view
					,'total' => $countAll
				)
			)
		);
	}
	
	public function saveForm(){
		$data = getData();
		$onEdit = ( int )$data['onEdit'];
		// $desc = 'Added new user, ' . $data['bmapsUfirstname'] . ' ' . $data['bmapsUlastname'] . ' with usertype ' . ( ( (int)$data['bmapsUtype'] == 1 )? 'Administrator' : ( ( (int)$data['bmapsUtype'] == 2 )? 'Secretary' : 'User' ) );
		$success = true;
		
		/* Check if username already exists */
		if( _checkData(
			array(
				'table' => 'bmapsu'
				,'field' => 'bmapsUname'
				,'value' => $data['bmapsUname']
				,'exwhere' => 'bmapsUID NOT IN(' . (int)$data['bmapsUID'] . ')'
			)
		) ){
			die(
				json_encode(
					array(
						'success' => true
						,'match' => 1
					)
				)
			);
		}
		
		if( $onEdit ){
			/* check if user still exists */
			if( !_checkData(
				array(
					'table' => 'bmapsu'
					,'field' => 'bmapsUID'
					,'value' => (int)$data['bmapsUID']
				)
			) ){
				die(
					json_encode(
						array(
							'success' => true
							,'match' => 2
						)
					)
				);
			}
			
			if( $data['modify'] == '0' ){
				$dateModified = $this->standards->getDateModified( $data['bmapsUID'], 'bmapsUID', 'bmapsu' );
				if( $data['dateModified'] != $dateModified->dateModified ){
					die(
						json_encode(
							array(
								'success' => true
								,'match' => 3
							)
						)
					);
				}
			}
			$desc = 'Modified ' . $data['bmapsUfirstname'] . ' ' . $data['bmapsUlastname'] . '.';
		}else{ $desc = 'Added new user, ' . $data['bmapsUfirstname'] . ' ' . $data['bmapsUlastname'] . ' with usertype ' . ( ( (int)$data['bmapsUtype'] == 1 )? 'Administrator' : ( ( (int)$data['bmapsUtype'] == 2 )? 'Secretary' : 'User' ) ); }
		
		
		 
		
		$this->db->trans_begin();
	 	$id = $this->model->saveForm( $data );
		
		/* save module access(Defaults) - new record */
		if( !$onEdit ){
			/* get all modules for users */
			$mtype = 0;
			if( $data['bmapsUtype'] == 1 ){
				$mtype = 2;
			}
			elseif( $data['bmapsUtype'] == 2 ){
				$mtype = 1;
			}
			else{
				$mtype = 0;
			}
			
			$moduleList = $this->model->getModuleList( $mtype );
			foreach( $moduleList as $rs ){
				$this->model->saveAModules(
					array(
						'idmodule' => $rs['idmodule']
						,'mtype' => $rs['mtype']
						,'save' => 1
						,'edit' => 1
						,'del' => 1
						,'print' => 0
						,'iduser' => $id
						,'sorter' => 0
					)
				);
			}
		}
		
		setLogs(
			array(
				'description' => $desc
				,'idmodule' => $data['idmodule']
				,'bmapsUID' => $this->userID 
			)
		);
		
		if( $this->db->trans_status() === FALSE ){
			$this->db->trans_rollback();
			$success = false;
		}
		else{
			$this->db->trans_commit();
		}
		
		die(
			json_encode(
				array(
					'success' => $success
					,'match' => 0
				)
			)
		);
	}
	
	public function retrieveRecord(){
		$params = getData();
		$ret = $this->model->retrieveRecords( $params );
		if( count( $ret ) == 0 ){
			die(
				json_encode(
					array(
						'success' => true
						,'view' => array()
						,'match' => 1
					)
				)
			);
		}
		die(
			json_encode(
				array(
					'success' => true
					,'view' => $ret
					,'match' => 0
				)
			)
		);
	}	
	
	public function deleteRecord(){
		$params = getData();
		$success = true;
		if( !_checkData(
			array(
				'table' => 'bmapsu'
				,'field' => 'bmapsUID'
				,'value' => (int)$params['bmapsUID']
			)
		) ){
			die(
				json_encode(
					array(
						'success' => true
						,'match' => 1
					)
				)
			);
		}
		
		$this->db->trans_begin();
		
		/* delete modules assigned */
		$this->model->deleteModuleAccess( $params );
		
		/* delete user record */
		$this->model->deleteRecord( $params );		
		
		setLogs(
			array(
				'description' => 'Deleted ' . $params['fullName']
				,'idmodule' => $params['idmodule']
				,'bmapsUID' => $this->userID
			)
		);
		if( $this->db->trans_status() === FALSE ){
			$this->db->trans_rollback();
			$success = false;
		}
		else{
			$this->db->trans_commit();
		}		
		
		die(
			json_encode(
				array(
					'success' => $success
					,'match' => 0
				)
			)
		);
	}
	
	public function processChangePassword(){
		$params = getData();
		$this->model->changePassword( $params );
		setLogs(
			array(
				'description' => 'Edited '.$this->fullname."'s password."
				,'idmodule' => 3
				,'bmapsUID' => $this->userID 
			)
		);
		die(
			json_encode(
				array(
					'success' => true
				)
			)
		);
	}
	
	public function getModules(){
		$params = getData();
		$view = $this->model->getModules( $params );
		die(
			json_encode(
				array(
					'success' => true
					,'view' => $view
					,'total' => count( $view )
				)
			)
		);
	}
	
	public function getUserList(){
		$params = getData();
		$view = $this->model->getUserList( $params );
		die(
			json_encode(
				array(
					'success' => true
					,'view' => $view
					,'total' => count( $view )
				)
			)
		);
	}
	
	public function savedModules(){
		$params = getData();
		$success = true;
		/* delete first all amodules record for this menu */
		$this->db->trans_begin();
		$this->model->deleteAmodulesRec( $params );
		$data = json_decode( $params['items'], true );
		for( $i = 0; $i < count( $data ); $i++ ){
			$data[$i]['iduser'] = $params['bmapsUID'];
			$data[$i]['sorter'] = $i+1;
		}
		if( count( $data ) > 0 ){
			$this->model->saveAmodulesRec( $data );
		}
		setLogs( array(
			'description' => 'Modified ' . $params['fullName'] . '\'s module access.'
			,'idmodule' => $params['idmodule']
			,'bmapsUID' => $this->userID 
		) );
		if( $this->db->trans_status() === FALSE ){
			$this->db->trans_rollback();
			$success = false;
		}
		else{
			$this->db->trans_commit();
		}
		die(
			json_encode(
				array(
					'success' => $success
					,'match' => 0
				)
			)
		);
	}
	
}